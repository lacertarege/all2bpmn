PDF2BPMN_DATA_DIR=%USERPROFILE%\.pdf_to_bpmn_visio
PDF2BPMN_DPI=300
PDF2BPMN_CONFIDENCE=0.75

# OCR recomendado para texto y layout del PDF/imagen
AZURE_DOCUMENT_INTELLIGENCE_ENDPOINT=https://<tu-document-intelligence-resource>.cognitiveservices.azure.com/
AZURE_DOCUMENT_INTELLIGENCE_KEY=<tu-document-intelligence-key>
AZURE_DOCUMENT_INTELLIGENCE_MODEL=prebuilt-layout
AZURE_DOCUMENT_INTELLIGENCE_API_VERSION=2024-11-30

# Aunque el nombre de estas variables diga "FOUNDY", aqui debes poner
# el recurso/deployment de Azure OpenAI conectado a tu proyecto de Azure AI Foundry.
# Recomendado para este proyecto:
#   Modelo del catalogo: gpt-4.1
#   Version del modelo: 2025-04-14
#   Nombre del deployment sugerido: gpt-4.1-bpmn
AZURE_FOUNDRY_ENDPOINT=https://<tu-azure-openai-resource>.openai.azure.com/
AZURE_FOUNDRY_DEPLOYMENT=gpt-4.1-bpmn
AZURE_FOUNDRY_API_KEY=<tu-azure-openai-key>
AZURE_FOUNDRY_API_VERSION=v1
# Alternativa si prefieres fijar la URL completa de Responses API:
# AZURE_FOUNDRY_RESPONSES_URL=https://<tu-azure-openai-resource>.openai.azure.com/openai/v1/responses
AZURE_FOUNDRY_RESPONSES_URL=

VISIO_POWERSHELL=powershell.exe
VISIO_BPMN_TEMPLATE_HINT=C:\Program Files\Microsoft Office\root\Office16\Visio Content\3082\BPMN_M.VSTX
VISIO_BPMN_STENCIL_HINT=C:\Program Files\Microsoft Office\root\Office16\Visio Content\3082\BPMN_M.VSSX
VISIO_KEEP_OPEN=false

# Opcional: normalizador BPMN basado en Open-BPMN si empaquetas su jar como CLI.
OPEN_BPMN_JAVA=java
OPEN_BPMN_JAR=
